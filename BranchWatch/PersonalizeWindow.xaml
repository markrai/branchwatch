<Window x:Class="BranchWatch.PersonalizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personalize Overlay"
        Width="420"
        MinWidth="320"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer x:Name="ContentScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Position"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <RadioButton x:Name="TopLeftRadio"
                             Grid.Row="0"
                             Grid.Column="0"
                             Content="Top left"
                             GroupName="Position"
                             Margin="0,0,8,8"
                             Checked="OnSettingChanged" />
                <RadioButton x:Name="TopRightRadio"
                             Grid.Row="0"
                             Grid.Column="1"
                             Content="Top right"
                             GroupName="Position"
                             Margin="0,0,0,8"
                             Checked="OnSettingChanged" />
                <RadioButton x:Name="BottomLeftRadio"
                             Grid.Row="1"
                             Grid.Column="0"
                             Content="Bottom left"
                             GroupName="Position"
                             Margin="0,0,8,0"
                             Checked="OnSettingChanged" />
                <RadioButton x:Name="BottomRightRadio"
                             Grid.Row="1"
                             Grid.Column="1"
                             Content="Bottom right"
                             GroupName="Position"
                             Checked="OnSettingChanged" />
            </Grid>

            <CheckBox x:Name="ShowOutlineCheckBox"
                      Grid.Row="2"
                      Content="Show outline"
                      Margin="0,0,0,8"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged" />

            <CheckBox x:Name="ShowRepositoryNameCheckBox"
                      Grid.Row="3"
                      Content="Show repository name"
                      Margin="0,0,0,4"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged" />

            <StackPanel x:Name="RepositoryLabelPanel"
                        Grid.Row="4"
                        Margin="24,0,0,16"
                        IsEnabled="False">
                <RadioButton x:Name="RepositoryFolderRadio"
                             Content="Folder name"
                             GroupName="RepositoryLabel"
                             Margin="0,0,0,4"
                             Checked="OnSettingChanged" />
                <RadioButton x:Name="RepositoryFullPathRadio"
                             Content="Full path"
                             GroupName="RepositoryLabel"
                             Checked="OnSettingChanged" />
            </StackPanel>

            <CheckBox x:Name="ShowActivityReasonCheckBox"
                      Grid.Row="5"
                      Content="Show activity reason"
                      Margin="0,0,0,16"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged" />

            <StackPanel Grid.Row="6" Margin="0,0,0,16">
                <TextBlock Text="Size"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Slider x:Name="SizeSlider"
                        Minimum="0.5"
                        Maximum="1.0"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="False"
                        ValueChanged="OnSizeSliderChanged" />
                <TextBlock x:Name="SizeLabel"
                           Margin="0,4,0,0"
                           Foreground="Gray" />
            </StackPanel>

            <StackPanel Grid.Row="7" Margin="0,0,0,16">
                <TextBlock Text="Background opacity"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Slider x:Name="OpacitySlider"
                        Minimum="0.2"
                        Maximum="0.85"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="False"
                        ValueChanged="OnOpacitySliderChanged" />
                <TextBlock x:Name="OpacityLabel"
                           Margin="0,4,0,0"
                           Foreground="Gray" />
            </StackPanel>

            <StackPanel Grid.Row="8" Margin="0,0,0,16">
                <TextBlock Text="Foreground opacity"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Slider x:Name="ForegroundOpacitySlider"
                        Minimum="0.2"
                        Maximum="1.0"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="False"
                        ValueChanged="OnForegroundOpacitySliderChanged" />
                <TextBlock x:Name="ForegroundOpacityLabel"
                           Margin="0,4,0,0"
                           Foreground="Gray" />
            </StackPanel>

            <StackPanel Grid.Row="9" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Font color"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Border x:Name="FontColorPreview"
                        Width="28"
                        Height="28"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnChooseColorClick" />
            </StackPanel>

            <Button Grid.Row="10"
                    Content="Close"
                    HorizontalAlignment="Right"
                    Padding="16,6"
                    Click="OnCloseClick" />
        </Grid>
    </ScrollViewer>
</Window>
